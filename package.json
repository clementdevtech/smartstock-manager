{
  "name": "smartstock-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",

  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3"
  },

  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",

    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://localhost:5173 && electron .\"",

    "build:client": "cd client && npm run build",

    "build": "npm run build:client && electron-builder"
  },

  "build": {
    "appId": "com.smartstock.pos",
    "productName": "SmartStock POS",

    "asar": false,
    "publish": null,

    "directories": {
      "output": "dist"
    },

    "files": [
      "electron/**/*",
      "client/dist/**/*",
      "server/**/*",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "server",
        "to": "server"
      }
    ],

    "win": {
      "icon": "electron/icon.ico",
      "target": "nsis"
    },

    "linux": {
      "target": "AppImage"
    },

    "mac": {
      "icon": "electron/icon.icns",
      "target": "dmg"
    }
  }
}

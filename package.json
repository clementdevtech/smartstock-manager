{
  "name": "smartstock-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "author": "Clement DevTech",
  "description": "SmartStock POS – Offline-first inventory & sales system",

  "engines": {
    "node": ">=20.11.0"
  },

  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "electron-rebuild": "^3.2.9",
    "wait-on": "^7.2.0"
  },

  "dependencies": {
    "@zxing/browser": "^0.1.5",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.7.3"
  },

  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3 --module-dir server",

    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",

    "dev": "npm run rebuild && concurrently -k \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://localhost:5173 && electron .\"",

    "build:client": "cd client && npm run build",
    "build:backend": "pkg server/server.js --targets node20-win-x64 --output server-dist/backend.exe",

    "rebuild": "electron-rebuild -f -w better-sqlite3 --module-dir server",

    "build": "npm run build:client && electron-builder",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3 --module-dir server",
    "build:win": "npm run rebuild:native && npm run build:client && electron-builder --win --publish always",
    "build:linux": "npm run build:client && electron-builder --linux --publish always",
    "build:mac": "npm run build:client && electron-builder --mac --publish always",

    "clear-cache": "node electron/clear-cache.js"
  },

  "build": {
    "appId": "com.smartstock.pos",
    "productName": "SmartStock POS",

    "npmRebuild": false,
    "buildDependenciesFromSource": true,

    "directories": {
      "output": "dist",
      "buildResources": "build"
    },

    "files": [
      "electron/**/*",
      "client/dist/**/*",
      "server/**/*",
      "package.json"
    ],

    "extraResources": [
      {
          "from": "server-dist/backend.exe",
          "to": "backend.exe"
        }
    ],

    "publish": [
      {
        "provider": "github",
        "owner": "clementdevtech",
        "repo": "smartstock-manager",
        "releaseType": "release"
      }
    ],

    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "SmartStock-POS-Setup-${version}-${arch}.exe"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "uninstallDisplayName": "SmartStock POS",
      "deleteAppDataOnUninstall": false
    },

    "linux": {
      "icon": "build",
      "target": ["AppImage", "deb"],
      "artifactName": "SmartStock-POS-${version}-${arch}.${ext}"
    },

    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "SmartStock-POS-${version}-${arch}.dmg",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist"
    }
  }
}
